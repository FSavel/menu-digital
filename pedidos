# ======================================================
# CRIAR PEDIDO
# ======================================================
@app.route("/pedido", methods=["POST"])
def pedido():

    nome = request.form.get("nome", "Cliente")
    pedido_raw = request.form.get("pedido", "")

    total = 0
    items_text = ""

    try:
        items = json.loads(pedido_raw) if pedido_raw else []

        linhas = []

        for item in items:
            price = float(item.get("price", 0))
            qty = int(item.get("qty", 1))

            total += price * qty
            linhas.append(f"{item.get('name')} x{qty}")

        items_text = " | ".join(linhas)

    except:
        items_text = pedido_raw

novo = pd.DataFrame([{
    "id": str(uuid.uuid4()),   # 👈 NOVO (IMPORTANTE)
    "nome": nome,
    "pedido": items_text,
    "total": total,
    "hora": hora_mocambique(),
    "status": "Recebido"
}])

    save_excel(Config.ORDERS_FILE, novo)

    return render_template(
        "pedido_sucesso.html",
        total=total,
        config=Config
    )


