# ======================================================
@app.route("/admin/dashboard")
def admin_dashboard():

    if not session.get("admin_logged_in"):
        return redirect(url_for("admin_login"))

    df = load_excel(Config.ORDERS_FILE)

    if df.empty:
        stats = {
            "total_pedidos": 0,
            "total_receita": 0,
            "pendentes": 0,
            "entregues": 0
        }
        pedidos = []
    else:
        stats = {
            "total_pedidos": len(df),
            "total_receita": float(df["total"].sum()),
            "pendentes": len(df[df["status"] == "Recebido"]),
            "entregues": len(df[df["status"] == "Entregue"])
        }
        pedidos = df.tail(10).to_dict(orient="records")

    return render_template(
        "admin/dashboard.html",
        stats=stats,
        pedidos=pedidos,
        config=Config
    )
    
# ======================================================
# PAINEL PEDIDOS (COZINHA)
# ======================================================
@app.route("/pedidos")
def pedidos():

    if not session.get("admin_logged_in"):
        return redirect(url_for("admin_login"))

    df = load_excel(Config.ORDERS_FILE)

    pedidos = df.to_dict(orient="records") if not df.empty else []
    total_dia = df["total"].fillna(0).sum() if not df.empty else 0

    return render_template(
        "pedidos.html",
        pedidos=pedidos,
        total_dia=total_dia,
        config=Config
    )


# ======================================================
# MARCAR COMO ENTREGUE
# ======================================================
@app.route("/entregar/<int:id>")
def entregar(id):

    df = load_excel(Config.ORDERS_FILE)

    if not df.empty and 0 <= id < len(df):
        df.at[id, "status"] = "Entregue"
        df.to_excel(Config.ORDERS_FILE, index=False)

    return redirect(url_for("pedidos"))


